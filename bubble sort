#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int arr[n];

    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    for(int pass = 0; pass < n - 1; pass++) {

        for(int i = 0; i < n - pass - 1; i++) {

            if(arr[i] > arr[i + 1]) {
                swap(arr[i], arr[i + 1]);
            }
        }
    }

    for(int i = 0; i < n; i++) {
        cout << arr[i] << " ";
    }

    return 0;
}